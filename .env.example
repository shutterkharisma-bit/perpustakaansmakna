# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=perpustakaan_smakna
DB_PORT=3306

# Application
APP_NAME="Perpustakaan SMA Kharisma Nurul Amal"
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost/perpustakaansmakna

# Session
SESSION_TIMEOUT=3600
SESSION_COOKIE_NAME=PERPUSTAKAAN_SESS

# File Upload
MAX_UPLOAD_SIZE=10485760
UPLOAD_PATH=uploads/

# QR Code
QR_CODE_SIZE=200
QR_CODE_LEVEL=M
QR_CODE_FORMAT=png
